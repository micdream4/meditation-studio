{
  "name": "meditation-studio-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "validate-env": "node --experimental-strip-types scripts/validate-env.ts",
    "validate:supabase": "node --experimental-strip-types scripts/validate-supabase-schema.ts",
    "validate:creem": "node --experimental-strip-types scripts/validate-creem.ts",
    "creem:doctor": "node --experimental-strip-types scripts/creem-doctor.ts",
    "generate-previews": "bash scripts/generate-previews.sh",
    "generate-voice-previews": "node --experimental-strip-types scripts/generate-voice-previews.ts",
    "generate-music": "python3 scripts/generate_music.py"
  },
  "dependencies": {
    "@audio/decode-mp3": "^1.1.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "elevenlabs": "^1.59.0",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
